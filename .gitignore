# ─────────────────────────────────────────────
#  JIBAYAT — .gitignore
# ─────────────────────────────────────────────

# ── Python ──────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
.eggs/
*.spec

# ── Environnements virtuels ──────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Base de données locale ───────────────────
fiscalite.db
fiscalite.db-shm
fiscalite.db-wal
database.db
*.db
*.sqlite
*.sqlite3

# ── Configuration locale (données sensibles) ─
config.json
last_update.txt

# ── Distribution PyInstaller ─────────────────
build/
dist/
*.rar
*.zip
*.7z

# ── Logs ────────────────────────────────────
*.log
logs/
build_log.txt

# ── IDE & Éditeurs ───────────────────────────
.vscode/
.idea/
*.suo
*.user
.DS_Store
Thumbs.db
.specify/
.gemini/

# ── Variables d'environnement ────────────────
.env
.env.local
.env.production

# ── Fichiers spéciaux Windows ────────────────
nul
nul/

# ── Fichiers d'export et d'upload ──────────
uploads/
static/exports/
*.pdf
*.xls
*.xlsx

# ── Scripts utilitaires locaux ───────────────
git_pull.bat
GIT_PULL_GITHUB.bat
LANCER.bat
build_exe.bat

# ── Scripts de maintenance/migration ─────────
fix_db.py
patch_db.py
migrate_tnb.py
tmp_sec.py
update_tarifs.py
import_excel.py

# ── Données de développement ─────────────────
backup_log.json
